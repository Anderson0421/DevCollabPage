---
    interface Props {
    title: string;
    descripcion: string;
    imagen : string;
    }

    const { title, descripcion, imagen } = Astro.props

---
<div>
    <div class="rounded-xl bg-gray-800 text-white p-7 w-max flex flex-col items-center">
        <img class="w-24 h-24 mb-4" src={imagen} alt="">
        <h1 class="font-bold text-xl mb-4">{title}</h1>
        <p class="w-80 text-center">{descripcion}</p>
    </div>
</div>